    "# =============================================================================\n",
    "# S12 --- GVAE TRAINING (v4b: z-only decoder + cyclical beta annealing)\n",
    "# =============================================================================\n",
    "\n",
    "log.info('=' * 70)\n",
    "log.info('STAGE 2: GVAE TRAINING')\n",
    "log.info('=' * 70)\n",
    "\n",
    "gvae = HopfGraphVAE(\n",
    "    encoder_model=encoder,\n",
    "    latent_dim=LATENT_DIM,\n",
    "    n_node_features_out=N_NODE_FEATURES_OUT,\n",
    ")\n",
    "\n",
    "n_frozen = sum(p.numel() for p in gvae.parameters() if not p.requires_grad)\n",
    "n_trainable = sum(p.numel() for p in gvae.parameters() if p.requires_grad)\n",
    "log.info('GVAE: frozen=%d, trainable=%d', n_frozen, n_trainable)\n",
    "\n",
    "# ── Cyclical beta annealing (Fu et al. 2019, NAACL) ──────────────────\n",
    "def cyclical_beta(epoch, n_epochs, n_cycles=BETA_N_CYCLES,\n",
    "                  ratio=BETA_CYCLE_RATIO, beta_max=BETA_MAX):\n",
    "    \"\"\"Cyclical beta schedule: M cycles of linear ramp then hold.\"\"\"\n",
    "    cycle_len = n_epochs / n_cycles\n",
    "    tau = ((epoch - 1) % cycle_len) / cycle_len  # position within current cycle\n",
    "    if tau < ratio:\n",
    "        return beta_max * (tau / ratio)\n",
    "    else:\n",
    "        return beta_max\n",
    "\n",
    "if len(hc_train_graphs) > 10:\n",
    "    gae_criterion = GAELoss(\n",
    "        lambda_edge=LAMBDA_EDGE, beta=0.0,\n",
    "        feature_weights=RECON_FEATURE_WEIGHTS,\n",
    "        free_bits=FREE_BITS,\n",
    "    )\n",
    "    trainable_gvae = [p for p in gvae.parameters() if p.requires_grad]\n",
    "    gae_optimizer = torch.optim.AdamW(trainable_gvae, lr=GAE_LR, weight_decay=GAE_WD)\n",
    "    gae_scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(gae_optimizer, T_max=GAE_EPOCHS)\n",
    "\n",
    "    gae_train_loader = PyGDataLoader(hc_train_graphs, batch_size=GAE_BS, shuffle=True)\n",
    "    gae_test_loader = PyGDataLoader(hc_test_graphs, batch_size=max(1, len(hc_test_graphs)))\n",
    "\n",
    "    gae_history = {'epoch': [], 'train_loss': [], 'test_loss': [],\n",
    "                   'beta': [], 'kl': [], 'kl_raw': [], 'cycle': []}\n",
    "\n",
    "    for epoch in range(1, GAE_EPOCHS + 1):\n",
    "        current_beta = cyclical_beta(epoch, GAE_EPOCHS)\n",
    "        current_cycle = int((epoch - 1) / (GAE_EPOCHS / BETA_N_CYCLES)) + 1\n",
    "        gae_criterion.beta = current_beta\n",
    "\n",
    "        gvae.train()\n",
    "        ep_loss, ep_kl, ep_kl_raw, nb = 0.0, 0.0, 0.0, 0\n",
    "        for batch_data in gae_train_loader:\n",
    "            gae_optimizer.zero_grad()\n",
    "            result = gvae(batch_data)\n",
    "            loss, ld = gae_criterion(result, batch_data, gvae_model=gvae)\n",
    "            loss.backward()\n",
    "            torch.nn.utils.clip_grad_norm_(trainable_gvae, max_norm=1.0)\n",
    "            gae_optimizer.step()\n",
    "            ep_loss += ld['total']\n",
    "            ep_kl += ld['kl']\n",
    "            ep_kl_raw += ld.get('kl_raw', ld['kl'])\n",
    "            nb += 1\n",
    "        gae_scheduler.step()\n",
    "\n",
    "        gvae.eval()\n",
    "        with torch.no_grad():\n",
    "            test_loss = sum(gae_criterion(gvae(tb), tb, gvae_model=gvae)[0].item()\n",
    "                           for tb in gae_test_loader)\n",
    "\n",
    "        gae_history['epoch'].append(epoch)\n",
    "        gae_history['train_loss'].append(ep_loss / max(nb, 1))\n",
    "        gae_history['test_loss'].append(test_loss)\n",
    "        gae_history['beta'].append(current_beta)\n",
    "        gae_history['kl'].append(ep_kl / max(nb, 1))\n",
    "        gae_history['kl_raw'].append(ep_kl_raw / max(nb, 1))\n",
    "        gae_history['cycle'].append(current_cycle)\n",
    "\n",
    "        if epoch % 20 == 0 or epoch == 1 or current_beta == 0.0:\n",
    "            log.info('  Epoch %3d | Train %.5f | Test %.5f | beta %.3f | KL %.4f (raw %.4f) | Cycle %d',\n",
    "                     epoch, gae_history['train_loss'][-1], test_loss, current_beta,\n",
    "                     gae_history['kl'][-1], gae_history['kl_raw'][-1], current_cycle)\n",
    "\n",
    "    log.info('GVAE training complete.')\n",
    "    torch.save(gvae.state_dict(), RESULTS_V4 / 'hopf_gvae_v4.pt')\n",
    "    pd.DataFrame(gae_history).to_csv(RESULTS_V4 / 'gvae_train_history.csv', index=False)\n",
    "else:\n",
    "    log.warning('Too few HC graphs (%d)', len(hc_train_graphs))"
